# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mars_ai
REDIS_URL=redis://localhost:6379

# APIs - Get free keys from:
# Stock/Finance: https://www.alphavantage.co (free tier: 5 calls/min)
# News: https://newsapi.org (free tier: 100 calls/day)
# Finance: https://finnhub.io (free tier: 60 calls/min)
ALPHA_VANTAGE_API_KEY=your_key_here
NEWS_API_KEY=your_key_here
FINNHUB_API_KEY=your_key_here
BRAVE_SEARCH_API_KEY=your_key_here
GOOGLE_AI_API_KEY=your_gemini_api_key

# AI
GEMINI_MODEL=gemini-1.5-flash

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Logging
LOG_LEVEL=info

# Cache
CACHE_TTL=300
MARKET_DATA_CACHE_TTL=60
